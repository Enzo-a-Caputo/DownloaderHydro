# ============================================================================
# DownloaderHydro — variáveis de ambiente
# Copie para `.env` e ajuste. O `.env` NÃO deve ser commitado.
#
# Paths relativos são resolvidos contra a pasta `webapp/` (não contra o CWD do
# uvicorn). Se preferir, use caminhos absolutos.
#
# Os comentários abaixo preservam, sempre que cabível, o texto original do
# `delineator-main/config.py` de Matthew Heberger (mghydro.com/watersheds), que
# foi quem documentou o significado de cada knob.
# ============================================================================

# ----------------------------------------------------------------------------
# Dados MERIT-Hydro / MERIT-Basins
# ----------------------------------------------------------------------------
# Pasta-raiz dos dados. Default = webapp/data/. Estrutura esperada dentro:
#   $MERIT_ROOT/raster/flowdir_basins/flowdir<NN>.tif
#     (Directory containing the merged, basin-scale MERIT-Hydro
#      flow direction rasters. Download from https://mghydro.com/watersheds/rasters)
#   $MERIT_ROOT/raster/accum_basins/accum<NN>.tif
#     (idem, flow accumulation. Download from https://mghydro.com/watersheds/rasters)
#   $MERIT_ROOT/shp/basins_level2/merit_hydro_vect_level2.shp
#     (Megabacias Pfafstetter nível 2 — vem com o repo do delineator original)
#   $MERIT_ROOT/shp/merit_catchments/cat_pfaf_<NN>_MERIT_Hydro_v07_Basins_v01.shp
#     (MERIT-Basins catchment shapefiles, hi-res. Download from:
#      https://www.reachhydro.org/home/params/merit-basins)
#   $MERIT_ROOT/shp/catchments_simplified/cat_pfaf_<NN>_MERIT_Hydro_v07_Basins_v01.shp
#     (Versão simplificada para bacias grandes (low-res). Download de:
#      https://mghydro.org/watersheds/share/catchments_simplified.zip)
#   $MERIT_ROOT/shp/rivers/riv_pfaf_<NN>_MERIT_Hydro_v07_Basins_v01.shp
#     (MERIT-Basins River flowline shapefiles. Mesma fonte do hi-res catchments)
MERIT_ROOT=data

# Cache rápido dos GeoDataFrames (gerado no primeiro uso de cada bacia).
# Original (delineator config.py): "Directory to store Python pickle files.
# Because it can be slow for Python to read shapefiles and create a GeoDataFrame.
# Once you have done this once, you can save time in the future by storing the
# GeoDataFrame as a .pkl file. Please note that these files can be large
# (Up to around 1 GB for large basins.)"
PICKLE_DIR=backend/storage/pickles

# Bacias Pfafstetter nível 2 a pré-carregar no boot.
# Vazio = boot rápido, cada bacia carrega no primeiro request (pickle gerado on-demand).
# América do Sul completa: 61,62,63,64,65,66,67
PRELOAD_BASINS=

# ----------------------------------------------------------------------------
# Inventário ANA (GeoPackage consolidado)
# ----------------------------------------------------------------------------
# Arquivo .gpkg com colunas: CODIGO, TIPOESTACA ('Pluviométrica'/'Fluviométrica'),
# geometry. Gerado por scripts/build_ana_inventory.py (ainda stub).
ANA_INVENTORY_PATH=backend/storage/estacoes_ana.gpkg

# ----------------------------------------------------------------------------
# Credenciais ANA (Hidro Webservice)
# ----------------------------------------------------------------------------
# Se preenchido, o servidor usa estas credenciais para todos os downloads.
# Deixe em branco para exigir que o usuário envie login/senha em cada requisição.
ANA_IDENTIFICADOR=
ANA_SENHA=

# ----------------------------------------------------------------------------
# Delineação — knobs absorvidos do delineator/config.py
# ----------------------------------------------------------------------------
# "Threshold for watershed size in km² above which the script will revert to
#  low-resolution mode."
LOW_RES_THRESHOLD=50000

# "If the requested watershed outlet is not inside a catchment, how far away
#  from the point should we look for the nearest catchment (in degrees).
#  0.025 recommended" — usamos 0.005 (~500m) por padrão para evitar
#  pegar catchment vizinho errado em pontos clicados perto de divisor.
SEARCH_DIST=0.005

# "Watersheds created with Merit-Hydro data tend to have many 'donut holes'
#  ranging from one or two pixels to much larger." Preencher?
FILL_HOLES=true

# "If FILL = True, you may choose to fill donut holes that are below a
#  certain size. This is the number of pixels, on the 3 arcsecond grid.
#  Set to 0 to fill ALL holes."
FILL_THRESHOLD=100

# "Threshold for number of upstream pixels that defines a stream.
#  These values worked well in my testing, but you might try changing if the
#  outlet is not getting snapped to a river centerline properly."
# THRESHOLD_SINGLE = quando a bacia é uma única unit catchment (cabeceira
# pequena); valor menor pega cursos d'água menores.
# THRESHOLD_MULTIPLE = bacia com várias unit catchments (rio principal);
# valor maior evita snap em afluentes pequenos próximos.
THRESHOLD_SINGLE=500
THRESHOLD_MULTIPLE=5000

# "On the web page map, if MAP_RIVERS is True, how many stream orders shall we
#  display? I recommend 4 or less. More than this and the browser may not
#  display all the rivers in a large watershed."
NUM_STREAM_ORDERS=3

# "If SIMPLIFY is True, set SIMPLIFY_TOLERANCE to a value in decimal degrees."
# (O flag SIMPLIFY do request decide ligar/desligar; a tolerância vem daqui.)
SIMPLIFY_TOLERANCE=0.0008

# ----------------------------------------------------------------------------
# Knobs do delineator que NÃO são expostos aqui (decididos por contexto webapp)
# ----------------------------------------------------------------------------
# OUTLETS_CSV: irrelevante (a webapp recebe ponto único via POST, não CSV).
# HIGH_RES: decidido por request (DelineateRequest.precision = high|low|auto).
# VERBOSE / PLOTS: sempre False (sem stdout poluído nem .jpg em disco).
# OUTPUT_DIR / OUTPUT_EXT / OUTPUT_CSV: sem geração de arquivos no servidor.
# MAKE_MAP / MAP_RIVERS / MAP_FOLDER: sem HTML estático (frontend faz a vis).
# MATCH_AREAS / AREA_MATCHING_THRESHOLD / MAX_DIST: feature de "match by area"
#   do CLI original; webapp não usa hoje (request é por (lat,lng), não área).

# ----------------------------------------------------------------------------
# Fila de downloads (huey + SQLite, sem Redis)
# ----------------------------------------------------------------------------
HUEY_DB_PATH=backend/storage/jobs.db
HUEY_IMMEDIATE=false  # true => executa inline (dev sem worker separado)

# ----------------------------------------------------------------------------
# Servidor
# ----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
